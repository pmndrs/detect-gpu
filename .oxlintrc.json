{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "builtin": true,
    "browser": true
  },
  "ignorePatterns": ["dist/**", "benchmarks/**"],
  "rules": {
    "typescript/no-explicit-any": "warn",
    "no-constant-condition": "off"
  },
  "overrides": [
    {
      "files": ["scripts/**/*.ts"],
      "env": {
        "node": true
      }
    }
  ]
}
